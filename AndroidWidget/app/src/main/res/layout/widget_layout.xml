<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_base"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    
    <!-- A háttérkép, aminek az átlátszóságát a csúszka állítja -->
    <ImageView
        android:id="@+id/img_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:src="@drawable/widget_bg" />
        
    <!-- Automatikus online sötétítő réteg (50% fekete) -->
    <FrameLayout
        android:id="@+id/online_dark_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />
        
    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Deye-Besen adatok"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />
            <ImageButton
                android:id="@+id/btn_refresh"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="#E2E8F0" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp">

            <GridLayout
                android:id="@+id/layout_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:alignmentMode="alignBounds"
                android:rowOrderPreserved="false"
                android:layout_gravity="center">
                
                <TextView android:id="@+id/tv_pv" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="" android:textColor="#E2E8F0" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_grid" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="" android:textColor="#E2E8F0" android:textSize="14sp" android:textStyle="bold" />
                
                <TextView android:id="@+id/tv_soc" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="" android:textColor="#E2E8F0" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_batt_power" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="" android:textColor="#E2E8F0" android:textSize="14sp" android:textStyle="bold" />
                
                <TextView android:id="@+id/tv_ups" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="" android:textColor="#E2E8F0" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_charger" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:text="" android:textColor="#E2E8F0" android:textSize="14sp" android:textStyle="bold" />
            </GridLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
